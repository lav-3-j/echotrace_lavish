{
  "manifest_version": 3,
  "name": "EchoTrace",
  "version": "1.0.0",
  "description": "Detect synthetic/bot content on Reddit using behavioral analysis + Gemini AI",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://www.reddit.com/*",
    "https://reddit.com/*",
    "https://generativelanguage.googleapis.com/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.reddit.com/*", "https://reddit.com/*"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  }
}
